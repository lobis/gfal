# xrootd-cern-test — Alma Linux 9 image with CERN CAs + XRootD Python bindings
#
# Used by integration tests (TestEosPilotXrootd) that require GSI authentication
# against eospilot.cern.ch via root://.  GSI auth needs CERN CA certificates in
# /etc/grid-security/certificates/ with OpenSSL hash naming, which is not
# available on macOS without this container.
#
# Build:
#   docker build --platform linux/amd64 \
#     -t xrootd-cern-test \
#     -f docker/Dockerfile.xrootd-cern-test .
#
# The repo is mounted read-only at /repo at container run time (not baked in)
# so that code changes are picked up without rebuilding the image.

FROM almalinux:9

# Install system dependencies.
# python3.12 is available in AlmaLinux 9 AppStream (no EPEL needed).
# xrootd-client provides GSI plugin libraries used by the pip xrootd package.
RUN dnf install -y \
        epel-release \
        dnf-plugins-core \
    && dnf config-manager --set-enabled crb \
    && dnf install -y \
        git \
        wget \
        openssl \
        python3.12 \
        python3.12-pip \
        xrootd-client \
        xrootd-client-libs \
        globus-proxy-utils \
        gfal2 \
        gfal2-util-scripts \
        python3-gfal2-util \
        gfal2-plugin-xrootd \
        gfal2-plugin-http \
        gfal2-plugin-file \
    && dnf clean all \
    && python3.12 -m pip install --upgrade pip --quiet

# Install CERN CAs into the system trust store AND /etc/grid-security/certificates/
# with OpenSSL hash naming (required by XRootD GSI auth via XRD_CADIR).
RUN mkdir -p /etc/grid-security/certificates \
    && \
    # CERN Root CA 2 (DER format from cafiles.cern.ch)
    wget -q "https://cafiles.cern.ch/cafiles/certificates/CERN%20Root%20Certification%20Authority%202.crt" \
         -O /tmp/cern-root-ca2.der \
    && openssl x509 -inform DER -in /tmp/cern-root-ca2.der -out /tmp/cern-root-ca2.pem \
    && cp /tmp/cern-root-ca2.pem /etc/pki/ca-trust/source/anchors/cern-root-ca2.pem \
    && HASH=$(openssl x509 -noout -hash -in /tmp/cern-root-ca2.pem) \
    && cp /tmp/cern-root-ca2.pem /etc/grid-security/certificates/${HASH}.0 \
    && \
    # CERN Grid CA (PEM despite .crt extension; note the (1) in filename)
    wget -q "https://cafiles.cern.ch/cafiles/certificates/CERN%20Grid%20Certification%20Authority(1).crt" \
         -O /tmp/cern-grid-ca.pem \
    && cp /tmp/cern-grid-ca.pem /etc/pki/ca-trust/source/anchors/cern-grid-ca.pem \
    && HASH=$(openssl x509 -noout -hash -in /tmp/cern-grid-ca.pem) \
    && cp /tmp/cern-grid-ca.pem /etc/grid-security/certificates/${HASH}.0 \
    && update-ca-trust \
    && rm -f /tmp/cern-*.pem /tmp/cern-*.der

# Install xrootd Python bindings, gfal runtime deps, and the temporary
# fsspec-xrootd fork explicitly. The package metadata must stay PyPI-safe, so
# the test image owns the fork installation instead of relying on pyproject
# direct references.
RUN python3.12 -m pip install --no-cache-dir \
        xrootd \
        "fsspec>=2023.1.0" \
        "aiohttp>=3.8.0" \
        "requests>=2.28.0" \
        truststore \
        "rich>=13.0.0" \
        "click>=8.0.0" \
    && python3.12 -m pip install --no-cache-dir --no-deps \
        "git+https://github.com/scikit-hep/fsspec-xrootd.git@gfal3-updates"

# Make python3.12 the default python3 so that run_gfal_docker scripts work.
RUN alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && alternatives --set python3 /usr/bin/python3.12 \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && python3.12 -m pip install --no-cache-dir pip --upgrade --quiet

# Environment: tell XRootD where to find CA certificates for GSI auth.
ENV XRD_CADIR=/etc/grid-security/certificates

# The gfal repo is mounted at /repo at runtime; gfal itself is installed
# per-run by run_gfal_docker() so code changes don't require an image rebuild.
