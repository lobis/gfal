# xrootd-cern-test — Alma Linux 9 image with CERN CAs + XRootD Python bindings
#
# Used by integration tests (TestEosPilotXrootd) that require GSI authentication
# against eospilot.cern.ch via root://.  GSI auth needs CERN CA certificates in
# /etc/grid-security/certificates/ with OpenSSL hash naming, which is not
# available on macOS without this container.
#
# Build:
#   docker build --platform linux/amd64 \
#     -t xrootd-cern-test \
#     -f docker/Dockerfile.xrootd-cern-test .
#
# The repo is mounted read-only at /repo at container run time (not baked in)
# so that code changes are picked up without rebuilding the image.

FROM almalinux:9

# Install system dependencies.
# python3.9 is kept for legacy gfal2-utils; the new gfal CLI runs on a Miniforge
# Python 3.11 environment installed below because conda-forge's xrootd builds
# do not yet support Python 3.12+.
RUN set -euxo pipefail \
    && for attempt in 1 2 3; do \
        if dnf install -y \
            --setopt=timeout=30 \
            --setopt=install_weak_deps=False \
            epel-release \
            dnf-plugins-core \
          && dnf config-manager --set-enabled crb \
          && dnf install -y \
            --setopt=timeout=30 \
            --setopt=install_weak_deps=False \
            git \
            wget \
            openssl \
            xrootd-client \
            xrootd-client-libs \
            globus-proxy-utils \
            gfal2 \
            gfal2-util-scripts \
            python3-gfal2-util \
            gfal2-plugin-xrootd \
            gfal2-plugin-http \
            gfal2-plugin-file; then \
          break; \
        fi; \
        if [ "$attempt" -eq 3 ]; then \
          exit 1; \
        fi; \
        dnf clean all || true; \
        sleep 10; \
      done \
    && dnf clean all

# Install CERN CAs into the system trust store AND /etc/grid-security/certificates/
# with OpenSSL hash naming (required by XRootD GSI auth via XRD_CADIR).
RUN mkdir -p /etc/grid-security/certificates \
    && \
    # CERN Root CA 2 (DER format from cafiles.cern.ch)
    wget -q "https://cafiles.cern.ch/cafiles/certificates/CERN%20Root%20Certification%20Authority%202.crt" \
         -O /tmp/cern-root-ca2.der \
    && openssl x509 -inform DER -in /tmp/cern-root-ca2.der -out /tmp/cern-root-ca2.pem \
    && cp /tmp/cern-root-ca2.pem /etc/pki/ca-trust/source/anchors/cern-root-ca2.pem \
    && HASH=$(openssl x509 -noout -hash -in /tmp/cern-root-ca2.pem) \
    && cp /tmp/cern-root-ca2.pem /etc/grid-security/certificates/${HASH}.0 \
    && \
    # CERN Grid CA (PEM despite .crt extension; note the (1) in filename)
    wget -q "https://cafiles.cern.ch/cafiles/certificates/CERN%20Grid%20Certification%20Authority(1).crt" \
         -O /tmp/cern-grid-ca.pem \
    && cp /tmp/cern-grid-ca.pem /etc/pki/ca-trust/source/anchors/cern-grid-ca.pem \
    && HASH=$(openssl x509 -noout -hash -in /tmp/cern-grid-ca.pem) \
    && cp /tmp/cern-grid-ca.pem /etc/grid-security/certificates/${HASH}.0 \
    && update-ca-trust \
    && rm -f /tmp/cern-*.pem /tmp/cern-*.der

# Install Miniforge and use conda-forge for the XRootD-enabled Python runtime.
RUN wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
         -O /tmp/miniforge.sh \
    && bash /tmp/miniforge.sh -b -p /opt/conda \
    && rm -f /tmp/miniforge.sh \
    && /opt/conda/bin/conda install -y -n base -c conda-forge \
         "python=3.11" \
         "aiohttp>=3.8.0" \
         "click>=8.0.0" \
         "fsspec>=2023.1.0" \
         "rich>=13.0.0" \
         "rich-click>=1.7.0" \
         truststore \
         "urllib3>=2.0.0" \
         xrootd \
    && /opt/conda/bin/python -m pip install --no-cache-dir --upgrade pip \
    && /opt/conda/bin/python -m pip install --no-cache-dir "fsspec-xrootd>=0.5.2" \
    && /opt/conda/bin/conda clean -afy

# Make the Miniforge Python runtime the default for the new gfal CLI.
RUN ln -sf /opt/conda/bin/python /usr/local/bin/python \
    && ln -sf /opt/conda/bin/python /usr/local/bin/python3 \
    && ln -sf /opt/conda/bin/python /usr/local/bin/python3.11 \
    && ln -sf /opt/conda/bin/pip /usr/local/bin/pip \
    && ln -sf /opt/conda/bin/pip /usr/local/bin/pip3

# Environment: make the conda-installed console scripts visible, point Python SSL
# at the system trust store (with the injected CERN CAs), and tell XRootD where
# to find CA certificates for GSI auth.
ENV PATH=/opt/conda/bin:$PATH \
    SSL_CERT_FILE=/etc/pki/tls/certs/ca-bundle.crt \
    REQUESTS_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt \
    CURL_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt \
    XRD_CADIR=/etc/grid-security/certificates

# The gfal repo is mounted at /repo at runtime; gfal itself is installed
# per-run by run_gfal_docker() so code changes don't require an image rebuild.
